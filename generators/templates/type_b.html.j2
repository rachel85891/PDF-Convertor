<!DOCTYPE html>
<html dir="rtl" lang="he">
<head>
    <meta charset="UTF-8">
    <style>
        @page {
            size: A4 landscape;
            margin: 1.5cm;
        }
        body {
            font-family: "David", "Arial", sans-serif;
            direction: rtl;
            text-align: right;
            font-size: 11px;
            color: #1a1a1a;
        }
        {{ font_css|safe }}
        .header {
            margin-bottom: 15px;
            border: 2px solid #111;
            padding: 10px 12px;
            background-color: #e3e3e3;
        }
        .header-top {
            display: table;
            width: 100%;
        }
        .logo-cell,
        .title-cell,
        .meta-cell {
            display: table-cell;
            vertical-align: middle;
        }
        .logo-cell {
            width: 18%;
            text-align: right;
        }
        .title-cell {
            width: 62%;
            text-align: center;
        }
        .meta-cell {
            width: 20%;
            text-align: left;
        }
        .company-logo {
            max-height: 42px;
            max-width: 95px;
            object-fit: contain;
        }
        .header h2 {
            margin: 2px 0;
            color: #000;
            font-size: 22px;
        }
        .header h3 {
            margin: 2px 0 0;
            color: #333;
            font-weight: normal;
            font-size: 13px;
        }
        .meta-line {
            font-size: 11px;
            margin: 0 0 3px;
        }
        table.data-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
            border: 2px solid #111;
            table-layout: fixed;
        }
        table.data-table th {
            background-color: #cecece;
            border: 1px solid #111;
            padding: 6px 4px;
            font-weight: bold;
            font-size: 10px;
        }
        table.data-table td {
            border: 1px solid #6a6a6a;
            padding: 5px 4px;
            text-align: center;
            font-size: 10px;
        }
        table.data-table tr.sabbath {
            background-color: #f0f0f0;
        }
        table.data-table tr:hover {
            background-color: #fffacd;
        }
        .summary-table {
            margin-top: 15px;
            width: 40%;
            float: left;
            border-collapse: collapse;
            border: 2px solid #111;
        }
        .summary-table td {
            border: 1px solid #6a6a6a;
            padding: 5px;
            font-size: 11px;
        }
        .summary-table .label {
            background-color: #dadada;
            font-weight: bold;
            width: 60%;
        }
        .clearfix {
            clear: both;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="header-top">
            <div class="logo-cell">
                {% if metadata.company_logo_path %}
                <img class="company-logo" src="{{ metadata.company_logo_path }}" alt="Company Logo">
                {% endif %}
            </div>
            <div class="title-cell">
                <h2>{{ metadata.company_name or "נ.ע. הנשר" }} בע"מ</h2>
                <h3>דוח נוכחות מפורט עם שעות נוספות</h3>
            </div>
            <div class="meta-cell">
                <p class="meta-line">שם עובד: {{ metadata.employee_name or "-" }}</p>
                <p class="meta-line">חודש: {{ metadata.report_period or "-" }}</p>
            </div>
        </div>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>תאריך</th>
                <th>יום</th>
                <th>מקום ע"נ</th>
                <th>כניסה</th>
                <th>יציאה</th>
                <th>הפסקה</th>
                <th>סה"כ</th>
                <th>שעות 100%</th>
                <th>שעות 125%</th>
                <th>שעות 150%</th>
            </tr>
        </thead>
        <tbody>
            {% for entry in entries %}
            <tr class="{{ 'sabbath' if 'שבת' in entry.day else '' }}">
                <td>{{ entry.date }}</td>
                <td>{{ entry.day }}</td>
                <td>{{ entry.location }}</td>
                <td>{{ entry.entry_time }}</td>
                <td>{{ entry.exit_time }}</td>
                <td>{{ entry.break_duration }}</td>
                <td>{{ entry.total_hours }}</td>
                <td>{{ regular_hours_by_row.get(loop.index0, "0.00") }}</td>
                <td>{{ entry.overtime_125 }}</td>
                <td>{{ entry.overtime_150 }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <table class="summary-table">
        <tr>
            <td class="label">ימים:</td>
            <td>{{ totals.total_days }}</td>
        </tr>
        <tr>
            <td class="label">סה"כ שעות:</td>
            <td>{{ "%.2f"|format(totals.total_hours) }}</td>
        </tr>
        <tr>
            <td class="label">שעות 100%:</td>
            <td>{{ "%.2f"|format(monthly_regular_hours) }}</td>
        </tr>
        <tr>
            <td class="label">שעות 125%:</td>
            <td>{{ "%.2f"|format(monthly_ot_125) }}</td>
        </tr>
        <tr>
            <td class="label">שעות 150%:</td>
            <td>{{ "%.2f"|format(monthly_ot_150) }}</td>
        </tr>
        <tr>
            <td class="label">בונוס:</td>
            <td>0</td>
        </tr>
        <tr>
            <td class="label">נסיעות:</td>
            <td>0</td>
        </tr>
    </table>

    <div class="clearfix"></div>
</body>
</html>
