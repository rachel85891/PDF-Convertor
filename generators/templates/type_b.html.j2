<!DOCTYPE html>
<html dir="rtl" lang="he">
<head>
    <meta charset="UTF-8">
    <style>
        @page {
            size: A4 landscape;
            margin: 1.5cm;
        }
        body {
            font-family: "Arial", "David", sans-serif;
            direction: rtl;
            text-align: right;
            font-size: 11px;
            color: #1a1a1a;
        }
        {{ font_css|safe }}
        .header {
            text-align: center;
            margin-bottom: 15px;
            border: 2px solid #000;
            padding: 10px;
            background-color: #e8e8e8;
        }
        .header h2 {
            margin: 5px 0;
            color: #000;
            font-size: 18px;
        }
        .header h3 {
            margin: 3px 0;
            color: #333;
            font-weight: normal;
            font-size: 13px;
        }
        table.data-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }
        table.data-table th {
            background-color: #d0d0d0;
            border: 1px solid #000;
            padding: 6px;
            font-weight: bold;
            font-size: 10px;
        }
        table.data-table td {
            border: 1px solid #666;
            padding: 5px;
            text-align: center;
            font-size: 10px;
        }
        table.data-table tr.sabbath {
            background-color: #f0f0f0;
        }
        .summary-table {
            margin-top: 15px;
            width: 40%;
            float: left;
            border-collapse: collapse;
        }
        .summary-table td {
            border: 1px solid #666;
            padding: 5px;
            font-size: 11px;
        }
        .summary-table .label {
            background-color: #e0e0e0;
            font-weight: bold;
            width: 60%;
        }
        .clearfix {
            clear: both;
        }
    </style>
</head>
<body>
    <div class="header">
        <h2>{{ metadata.company_name or 'נ.ע. הנשר בע"מ' }}</h2>
        <h3>דוח נוכחות מפורט עם שעות נוספות</h3>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>תאריך</th>
                <th>יום</th>
                <th>מקום ע"נ</th>
                <th>כניסה</th>
                <th>יציאה</th>
                <th>הפסקה</th>
                <th>סה"כ</th>
                <th>שעות 100%</th>
                <th>שעות 125%</th>
                <th>שעות 150%</th>
            </tr>
        </thead>
        <tbody>
            {% for entry in entries %}
            <tr class="{{ 'sabbath' if 'שבת' in entry.day else '' }}">
                <td>{{ entry.date }}</td>
                <td>{{ entry.day or "-" }}</td>
                <td>{{ entry.location or "-" }}</td>
                <td>{{ entry.entry_time }}</td>
                <td>{{ entry.exit_time }}</td>
                <td>{{ entry.break_duration }}</td>
                <td>{{ entry.total_hours }}</td>
                <td>{{ regular_hours_by_row.get(loop.index0, "0.00") }}</td>
                <td>{{ entry.overtime_125 }}</td>
                <td>{{ entry.overtime_150 }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <table class="summary-table">
        <tr><td class="label">ימים:</td><td>{{ totals.total_days }}</td></tr>
        <tr><td class="label">סה"כ שעות:</td><td>{{ "%.2f"|format(totals.total_hours) }}</td></tr>
        <tr><td class="label">שעות 100%:</td><td>{{ "%.2f"|format(monthly_regular_hours) }}</td></tr>
        <tr><td class="label">שעות 125%:</td><td>{{ "%.2f"|format(monthly_ot_125) }}</td></tr>
        <tr><td class="label">שעות 150%:</td><td>{{ "%.2f"|format(monthly_ot_150) }}</td></tr>
        <tr><td class="label">בונוס:</td><td>0</td></tr>
        <tr><td class="label">נסיעות:</td><td>0</td></tr>
    </table>
    <div class="clearfix"></div>
</body>
</html>
